# Supabase — Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=

# Publishable key (antes "anon") — segura en el cliente, respeta RLS
SUPABASE_KEY=

# Secret key (antes "service_role") — SOLO servidor, nunca en el navegador
SUPABASE_SERVICE_KEY=

# Contraseña Postgres directa (opcional). NO nombrar SUPABASE_DB — rompe `supabase db push`.
# SUPABASE_DB_PASSWORD=

# Alternativa explícita Nuxt:
# NUXT_PUBLIC_SUPABASE_URL=
# NUXT_PUBLIC_SUPABASE_KEY=
CURSOR_API_KEY=

# Perenual plant encyclopedia (species tab) — https://perenual.com/user/developer
PERENUAL_API_KEY=

# User home location for weather (optional defaults)
NUXT_PUBLIC_HOME_LAT=40.4168
NUXT_PUBLIC_HOME_LON=-3.7038

# Web Push (Phase 3)
NUXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=
